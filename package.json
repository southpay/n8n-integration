{
  "name": "n8n-nodes-southpay",
  "version": "0.1.2",
  "description": "n8n community node for SouthPay crypto payments",
  "license": "MIT",
  "author": {
    "name": "SouthPay",
    "email": "tech@southpay.io"
  },
  "keywords": ["n8n-community-node-package", "southpay", "crypto", "payments"],
  "homepage": "https://github.com/southpay/n8n-integration#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/southpay/n8n-integration.git"
  },
  "bugs": {
    "url": "https://github.com/southpay/n8n-integration/issues"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-icons.mjs",
    "typecheck": "tsc --noEmit"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/SouthPayOAuth2Api.credentials.js"],
    "nodes": [
      "dist/nodes/SouthPay/SouthPay.node.js",
      "dist/nodes/SouthPay/SouthPayTrigger.node.js"
    ]
  },
  "files": ["dist"],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
